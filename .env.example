CELERY_RESULT_BACKEND=redis://localhost:6379/1

PRESTASHOP_BASE_URL=https://example.com
PRESTASHOP_API_KEY=change-me

ICG_MSSQL_SERVER=localhost
ICG_MSSQL_DATABASE=ICG
ICG_MSSQL_USER=sa
ICG_MSSQL_PASSWORD=change-me
ICG_MSSQL_DRIVER=ODBC Driver 18 for SQL Server
