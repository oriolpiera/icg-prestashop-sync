DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=unsafe-development-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

DATABASE_NAME=icg_prestashop_sync
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

PRESTASHOP_BASE_URL=http://localhost
PRESTASHOP_API_KEY=
PRESTASHOP_DEFAULT_LANGUAGE_ID=1
PRESTASHOP_DEFAULT_CATEGORY_ID=2
PRESTASHOP_ROOT_CATEGORY_ID=2
PRESTASHOP_DEFAULT_TAX_RULES_GROUP_ID=0

ICG_MSSQL_SERVER=localhost
ICG_MSSQL_DATABASE=ICG
ICG_MSSQL_USER=sa
ICG_MSSQL_PASSWORD=change-me
ICG_MSSQL_DRIVER=ODBC Driver 18 for SQL Server
ICG_MSSQL_LOGIN_TIMEOUT=10
ICG_MSSQL_QUERY_TIMEOUT=30
ICG_MSSQL_TRUST_SERVER_CERTIFICATE=true
